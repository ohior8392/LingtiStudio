# 噼哩噼哩 Pilipili-AutoVideo - 环境变量配置
# 复制此文件为 .env 并填入你的 API Keys
# 环境变量优先级高于 configs/config.yaml

# ── LLM 配置（选择一个提供商）────────────────────────────────
LLM_PROVIDER=deepseek  # deepseek / kimi / minimax / zhipu / gemini / openai

DEEPSEEK_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
ZHIPU_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── 图像生成（Nano Banana / Gemini）──────────────────────────
# 与 GEMINI_API_KEY 共用同一个 Key

# ── 视频生成 ─────────────────────────────────────────────────
VIDEO_PROVIDER=kling  # kling / seedance

KLING_API_KEY=
KLING_API_SECRET=

VOLCENGINE_API_KEY=  # Seedance (字节跳动火山引擎)

# ── 记忆系统（可选）──────────────────────────────────────────
MEM0_API_KEY=  # 如果使用 Mem0 Cloud，填入此 Key
